    "typography": {
      "display": { "fontSize": "36px", "fontWeight": "700", "letterSpacing": "-0.02em" },
      "h1": { "fontSize": "24px", "fontWeight": "700", "letterSpacing": "-0.01em" },
      "h2": { "fontSize": "20px", "fontWeight": "600" },
      "h3": { "fontSize": "16px", "fontWeight": "600" },
