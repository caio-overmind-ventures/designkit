{
  "meta": {
    "source": "app.cal.com",
    "extractedAt": "2026-03-13",
    "modes": ["light", "dark"]
  },
  "character": {
    "density": "compact",
    "corners": "rounded",
    "elevation": "subtle",
    "borders": "thin",
    "palette": "monochromatic",
    "feel": "Clean, professional scheduling app with subtle depth via inset/outset shadows on primary buttons. Compact density with rounded corners (8-10px). Neutral grayscale palette with teal/green accents for active states.",
    "iconography": {
      "style": "monochromatic, stroke-only",
      "weight": "1.5px stroke",
      "size": "16px default, 20px nav",
      "color": "currentColor",
      "library": "Lucide (custom subset)",
      "never": "no emojis, no filled icons, no multi-color icons"
    }
  },
  "components": {
    "button-primary": {
      "borderRadius": "10px",
      "padding": "8px 10px",
      "fontWeight": "500",
      "fontSize": "14px",
      "lineHeight": "14px",
      "height": "32px",
      "borderWidth": "1px",
      "letterSpacing": "normal",
      "shadow": "0px 2px 3px 0px rgba(0,0,0,0.06), 0px 1px 1px 0px rgba(0,0,0,0.08), 1px 4px 8px 0px rgba(0,0,0,0.12), 0px 2px 0.4px 0px rgba(255,255,255,0.12) inset, 0px -3px 2px 0px rgba(0,0,0,0.04) inset",
      "light": { "backgroundColor": "#fafafa", "color": "#000", "borderColor": "#fafafa" },
      "dark": { "backgroundColor": "#fafafa", "color": "#000", "borderColor": "#fafafa" }
