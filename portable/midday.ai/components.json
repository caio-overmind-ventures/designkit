  "character": {
    "density": "compact",
    "corners": "sharp",
    "elevation": "flat",
    "borders": "thin",
    "palette": "monochromatic-warm",
    "feel": "Minimal financial interface. Almost brutalist — zero border-radius on functional elements, thin 1px borders, no shadows, no elevation. Warm cream backgrounds in light mode, pure black in dark. Display headings use a serif font (Hedvig Letters Serif) while everything else is sans-serif (Hedvig Letters Sans). Numbers are large and light-weight. The design trusts whitespace and typography hierarchy over visual decoration.",
    "iconography": {
      "style": "monochromatic, stroke-only, Lucide-style",
      "weight": "1.5px stroke",
      "size": "20px default, 16px in compact contexts",
      "color": "currentColor (inherits text color — foreground or muted-foreground)",
      "never": "No colored emojis, no filled icons, no multi-color icons. The only colored elements are small solid color squares used as category indicators in tables.",
      "library": "Lucide React recommended"
    }
  },
  "components": {
    "button-primary": {
      "borderRadius": "0px",
      "padding": "8px 16px",
      "fontWeight": "500",
      "fontSize": "14px",
      "height": "36px",
      "borderWidth": "0px",
      "backgroundColor": "rgb(24, 24, 27)",
      "color": "rgb(250, 250, 250)",
      "boxShadow": "none",
      "letterSpacing": "normal"
    },
    "button-secondary": {
      "borderRadius": "0px",
      "padding": "8px 16px",
      "fontWeight": "500",
      "fontSize": "14px",
      "height": "36px",
      "borderWidth": "1px",
      "backgroundColor": "transparent",
      "boxShadow": "none"
    },
