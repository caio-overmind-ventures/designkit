      "fontWeight": "500",
      "fontSize": "14px",
      "height": "32px",
      "borderWidth": "1px",
      "backgroundColor": "transparent",
      "note": "Small icon-like buttons (sidebar actions, row actions) use pill shape. Larger CTA buttons use 0px radius."
    },
    "button-destructive": {
      "borderRadius": "0px",
      "padding": "8px 16px",
